{
  "expo": {
    "name": "VibeMeter",
    "slug": "vibemeter",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "vibemeter",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true
        },
        "NSMicrophoneUsageDescription": "VibeMeter needs microphone access to record your experience for red flag analysis.",
        "NSSpeechRecognitionUsageDescription": "VibeMeter uses speech recognition to transcribe your spoken experience."
      },
      "bundleIdentifier": "com.vibemeter.app"
    },
    "android": {
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "RECORD_AUDIO"
      ],
      "package": "com.vibemeter.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-speech-recognition",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": "VibeMeter needs microphone access to record your experience for red flag analysis."
        }
      ]
    ]
  }
}